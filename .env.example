# Copiá este archivo a `.env` y completá los valores reales.
# IMPORTANTE: NO subas `.env` al repositorio (ya está en .gitignore).

# --- Base de datos (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql://USUARIO:CONTRASENA@localhost:5432/microbuses_sig

# --- Seguridad / JWT ---
# Generá una clave fuerte con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Entorno / red ---
ENVIRONMENT=development
# Orígenes permitidos para CORS, separados por coma. Vacío = defaults de desarrollo.
ALLOWED_ORIGINS=
# Requerir JWT (?token=...) en el WebSocket de posiciones (true/false)
WS_REQUIRE_AUTH=false

# --- Cloudinary (almacenamiento de imágenes) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
